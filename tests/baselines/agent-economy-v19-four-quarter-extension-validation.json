    {
      "issue": "population-drift-was-measured-before-live-adapter-alignment",
      "effect": "The candidate appeared to conserve population while legacy migration changed it, even though the live adapter later synchronized household weights.",
      "fix": "Finalize the quarter live-state adapter before building the engine comparison; retain a zero population-drift release limit."
    },
    {
      "issue": "population-growth-minted-default-household-assets",
      "effect": "A legacy population increase created a household with default cash and grain and triggered accounting rollback.",
      "fix": "Population synchronization changes household structure without seeding cash or inventory."
    },
    {
      "issue": "protected-emergency-reserve-was-too-large",
      "effect": "A 0.5 food-per-person reserve preserved too much food when legacy exhausted stores and households departed.",
      "fix": "Calibrate the protected reserve to 0.3 food per represented family while retaining the 3.0 food-per-person activation threshold."
    },
    {
      "issue": "daily-food-demand-used-zero-or-one-stochastic-rounding",
      "effect": "Small daily targets accumulated large quarter-level variance; the fixed extension seed consumed 31.1629 food against a theoretical 22.55 target.",
      "fix": "Consume exact four-decimal daily food quantities and normalize arithmetic after every deduction."
    }
  ],
